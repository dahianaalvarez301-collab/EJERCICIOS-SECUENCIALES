ALGORITMO DISTANCIA_PUNTOS
    ESCRIBIR "COORDENADAS DEL PUNTO 1 (X1, Y1):"
    LEER X1, Y1
    ESCRIBIR "COORDENADAS DEL PUNTO 2 (X2, Y2):"
    LEER X2, Y2
    // Formula: raiz((x2-x1)^2 + (y2-y1)^2)
    DIST = RC((X2-X1)^2 + (Y2-Y1)^2)
    ESCRIBIR "LA DISTANCIA ENTRE LOS PUNTOS ES: ", DIST
FINALGORITMO
