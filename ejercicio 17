ALGORITMO HORA_LLEGADA
    ESCRIBIR "HORA DE SALIDA (HH, MM, SS):"
    LEER HH, MM, SS
    ESCRIBIR "TIEMPO DE VIAJE EN SEGUNDOS:"
    LEER T
    // Convertir todo a segundos, sumar y volver a convertir
    INICIO_SEGUNDOS = HH * 3600 + MM * 60 + SS
    TOTAL_SEGUNDOS = INICIO_SEGUNDOS + T
    
    HORA_FIN = TRUNC(TOTAL_SEGUNDOS / 3600) MOD 24
    MIN_FIN = TRUNC((TOTAL_SEGUNDOS MOD 3600) / 60)
    SEG_FIN = TOTAL_SEGUNDOS MOD 60
    
    ESCRIBIR "LA HORA DE LLEGADA ES: ", HORA_FIN, ":", MIN_FIN, ":", SEG_FIN
FINALGORITMO
