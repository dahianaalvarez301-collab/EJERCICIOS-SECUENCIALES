ALGORITMO TIEMPO_ALCANCE
	ESCRIBIR "DIGITE DISTANCIA ENTRE VEHICULOS (KM)"
	LEER D
	ESCRIBIR "VELOCIDAD VEHICULO LENTO (KM/H)"
	LEER V1
	ESCRIBIR "VELOCIDAD VEHICULO RAPIDO (KM/H)"
	LEER V2
	TIEMPO_HORAS = D / (V2 - V1)
	TIEMPO_MINUTOS = TIEMPO_HORAS * 60
	ESCRIBIR "EL TIEMPO DE ALCANCE ES: ", TIEMPO_MINUTOS, " MINUTOS"
FINALGORITMO
