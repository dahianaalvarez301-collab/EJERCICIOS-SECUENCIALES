ALGORITMO CALCULOSUELDOVENDEDOR
	ESCRIBIR "PROGRAMA PARA CALCULAR SUELDO TOTAL CON COMISIONES"
	ESCRIBIR "DIGITE EL SUELDO BASE"
	LEER SUELDO_BASE
	ESCRIBIR "DIGITE VALOR DE LA VENTA 1"
	LEER V1
	ESCRIBIR "DIGITE VALOR DE LA VENTA 2"
	LEER V2
	ESCRIBIR "DIGITE VALOR DE LA VENTA 3"
	LEER V3
	COMISION = (V1 + V2 + V3) * 0.10
	TOTAL = SUELDO_BASE + COMISION
	ESCRIBIR "EL DINERO POR COMISIONES ES: ", COMISION
	ESCRIBIR "EL SUELDO TOTAL A RECIBIR ES: ", TOTAL
FINALGORITMO
