ALGORITMO CALIFICACION_FINAL
	ESCRIBIR "PROGRAMA PARA CALCULAR NOTA FINAL"
	ESCRIBIR "DIGITE LAS TRES CALIFICACIONES PARCIALES"
	LEER P1, P2, P3
	ESCRIBIR "DIGITE NOTA EXAMEN FINAL"
	LEER EF
	ESCRIBIR "DIGITE NOTA TRABAJO FINAL"
	LEER TF
	PROMEDIO_P = (P1 + P2 + P3) / 3
	NOTA_FINAL = (PROMEDIO_P * 0.55) + (EF * 0.30) + (TF * 0.15)
	ESCRIBIR "LA CALIFICACION FINAL ES: ", NOTA_FINAL
FINALGORITMO
